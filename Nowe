<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Zawody</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="logo">LOGO</h2>

        <div class="filter">
            <input type="checkbox"> Imię<br>
            <input type="checkbox"> Wiek
        </div>

        <nav class="menu">
            <a href="#">Opcje</a>
            <a href="#">Zawody</a>
            <a href="#" class="active">Wyloguj</a>
        </nav>
    </aside>

    <!-- MAIN -->
    <main class="main">

        <!-- TABELA -->
        <table class="players">
            <tr>
                <th>Poz.</th>
                <th>Imię</th>
                <th>Wiek</th>
                <th>Aktywny</th>
                <th>Data</th>
            </tr>
            <tr>
                <td>1</td>
                <td>XD1</td>
                <td>18</td>
                <td>✔</td>
                <td>18.03.2023</td>
            </tr>
            <tr>
                <td>2</td>
                <td>XD2</td>
                <td>34</td>
                <td>X</td>
                <td>10.04.2024</td>
            </tr>
            <tr>
                <td>3</td>
                <td>XD3</td>
                <td>12</td>
                <td>✔</td>
                <td>18.04.2024</td>
            </tr>
        </table>

        <!-- SEKCJA DOLNA -->
        <div class="bottom">

            <!-- FORMULARZ -->
            <div class="form-box">
                <h3>Dodaj zawodnika</h3>

                <input type="text" placeholder="Imię">
                <input type="text" placeholder="Nazwisko">
                <input type="number" placeholder="Wiek">
                <input type="date">

                <button>Dodaj</button>
            </div>

            <!-- PANEL PRAWY -->
            <div class="image-box">
                Obraz / panel
            </div>

        </div>

        <footer>
            Autor...
        </footer>

    </main>

</div>

</body>
</html>
