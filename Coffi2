<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CoffiShop</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app">
        <!-- Górny pasek -->
        <header>
            <div class="logo">
                Coffi <span class="cup">☕</span>
            </div>
            <nav>
                <a href="#">Home</a>
                <a href="#">Orders</a>
                <a href="#">Blog</a>
                <a href="#">Coffe types</a>
            </nav>
        </header>

        <div class="main-content">
            <!-- Lewa pomarańczowa sekcja -->
            <div class="order-section">
                <h1>Calculate your order</h1>
                
                <div class="form">
                    <div class="input-group">
                        <label>Enter coffee name</label>
                        <input type="text" placeholder="">
                    </div>
                    
                    <div class="input-group">
                        <label>Enter coffee weight</label>
                        <input type="text" placeholder="">
                    </div>
                    
                    <button class="process-btn">Process</button>
                    
                    <div class="price">
                        Order price: <span class="dash">—</span>
                    </div>
                </div>
            </div>

            <!-- Prawa biała sekcja -->
            <div class="menu-section">
                <h2>Menu</h2>
                <ul>
                    <li>Arabica</li>
                    <li>Robusta</li>
                    <li>Green</li>
                    <li>Mocha</li>
                    <li>No-caffeine</li>
                </ul>
                <button class="order-btn">Order it!</button>
            </div>
        </div>
    </div>
</body>
</html>
