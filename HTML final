<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CoffiShop</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jua&family=Lemon&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

   
    <nav class="nav-area">
        <a href="#">Home</a>
        <a href="#">Orders</a>
        <a href="#">Blog</a>
        <a href="#">Coffe types</a>
    </nav>

    <
    <div class="logo-box">
        <span class="logo-icon">☕</span>
        <span class="logo-text">Coffi</span>
    </div>

    
    <section class="calculator-area">
        <h2 class="title-brown">Calculate your order</h2>

        <div class="form">
            <div class="form-box">
                <label for="coffee-name">Enter coffe name</label>
                <input type="text" id="coffee-name" placeholder="[value]">
            </div>

            <div class="form-box">
                <label for="coffee-weight">Enter coffe weight</label>
                <input type="text" id="coffee-weight" placeholder="[value]">
            </div>

            <div class="form-actions">
                <button class="button process-btn">Process</button>
                <span class="price-text">Order price:</span>
            </div>
        </div>
    </section>

    
    <aside class="main-right">
        <h2 class="menu-title">Menu</h2>
        <ul class="menu-list">
            <li>Arabica</li>
            <li>Robusta</li>
            <li>Green</li>
            <li>Mocha</li>
            <li>No-caffine</li>
        </ul>
        <button class="button order-btn">Order it!</button>
    </aside>

    
    <footer class="footer-area">
        <span class="copyright-icon">©</span>
        <span class="copyright-text">2024, Coffi</span>
    </footer>

</div>

</body>
</html>
